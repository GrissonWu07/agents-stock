# 使用官方Python镜像作为基础镜像
FROM swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/python:3.12-slim

# 设置时区环境变量
ENV TZ=Asia/Shanghai
ENV LOCAL_MARKET_DATA_DIR=/app/data/local_sources
ENV MARKET_DATA_CACHE_ENABLED=true
ENV STOCK_ANALYSIS_ASYNC_REFRESH_ENABLED=false

# 设置工作目录
WORKDIR /app

# 安装Node.js (pywencai需要)、中文字体 (PDF生成需要) 和时区数据
RUN apt-get update && apt-get install -y \
    curl \
    gnupg \
    fonts-noto-cjk \
    fonts-wqy-zenhei \
    fonts-wqy-microhei \
    fontconfig \
    tzdata \
    && ln -snf /usr/share/zoneinfo/$TZ /etc/localtime \
    && echo $TZ > /etc/timezone \
    && curl -fsSL https://deb.nodesource.com/setup_18.x | bash - \
    && apt-get install -y nodejs \
    && fc-cache -fv \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# 验证安装
RUN node --version && npm --version

# 复制依赖文件
COPY requirements.txt .

# 安装Python依赖 - 修改后的部分
# 永久配置pip使用国内镜像源并增加超时时间[1](@ref)[2](@ref)
RUN pip config set global.index-url https://pypi.tuna.tsinghua.edu.cn/simple/ && \
    pip config set global.trusted-host pypi.tuna.tsinghua.edu.cn && \
    pip install --no-cache-dir --default-timeout=1000 -r requirements.txt

# 复制项目文件
COPY . .

# 写入镜像版本信息。Docker 构建上下文会排除 .git，因此 CI/部署脚本必须通过
# build args 注入当前 git revision；未注入时保留源码中的 version.json 兜底。
ARG APP_VERSION=
ARG APP_VERSION_DISPLAY=
ARG APP_VERSION_TAG=
ARG APP_REVISION=
RUN APP_VERSION="$APP_VERSION" \
    APP_VERSION_DISPLAY="${APP_VERSION_DISPLAY:-$APP_VERSION}" \
    APP_VERSION_TAG="$APP_VERSION_TAG" \
    APP_REVISION="$APP_REVISION" \
    python -m app.version_info --write /app/version.json

# 创建必要的目录
RUN mkdir -p /app/data/local_sources && chmod -R 777 /app/data

# 暴露 Python API 默认端口
EXPOSE 8501

# 设置健康检查
HEALTHCHECK CMD curl --fail http://localhost:8501/api/health || exit 1

# 启动 Python API
CMD ["python", "app/gateway.py"]

